{
  "name": "biborne-desktop",
  "version": "1.0.4",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/copy-vendor.js && electron .",
    "dist": "node scripts/copy-vendor.js && electron-builder"
  },
  "dependencies": {
    "socket.io-client": "^4.8.3",
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^43.1.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "fr.biborne.messagerie",
    "productName": "Biborne Messagerie",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "build/**/*",
      "!node_modules/electron-builder/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "AdamChela",
      "repo": "biborne-desktop",
      "releaseType": "release"
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "category": "public.app-category.business",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    }
  }
}
